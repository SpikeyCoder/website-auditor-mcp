# Website Auditor MCP — configuration
# Copy to `.env` and fill in. NEVER commit the real .env (see .gitignore).

# Base URL of the Website Auditor API portal (the SpikeyCoder/website-auditor-api service).
# This is the service the MCP wraps. Default is the public production host.
WA_API_BASE_URL=https://api.website-auditor.io

# Base URL of the Website Auditor site (used to build shareable report URLs).
WA_SITE_URL=https://website-auditor.io

# Per-user API key minted from a Website Auditor Pro account (starts with "wa_").
# Set this in the MCP client's server config. A limited free tier is gated on
# this key; Pro tools require the key's account to hold an active subscription.
WA_API_KEY=

# Where callers are sent to upgrade / subscribe. Surfaced in auth + quota errors.
WA_UPGRADE_URL=https://website-auditor.io/admin_portal

# Free-tier metering (MCP-side guardrails layered on top of the API's own limits).
# The API portal itself enforces a hard daily cap per key; these bound the free
# tier further so the MCP can't be used as a free API.
WA_FREE_DAILY_AUDIT_LIMIT=3
WA_FREE_MAX_DOMAINS=1

# Request timeout (ms) for calls to the API portal.
WA_REQUEST_TIMEOUT_MS=120000

# Audit cache TTL (ms). A domain audited within this window is reused instead of
# spending a fresh audit against the daily quota (used by compare_competitors).
# Defaults to 24h, mirroring the upstream engine's AI-visibility cache.
WA_AUDIT_CACHE_TTL_MS=86400000

# Subscription tier cache TTL (ms). The Pro/free tier is resolved from the live
# GET /api/subscription endpoint and cached per key for this window so it isn't a
# round-trip on every tool call. Short by default (60s) so upgrades/downgrades
# reflect quickly.
WA_SUBSCRIPTION_CACHE_TTL_MS=60000

# EXPLICIT local-dev tier override — NOT the default path. Tier is normally read
# from the live subscription endpoint. Set to "pro" or "free" only to exercise a
# tier locally without a real subscription. Ignored when WA_API_KEY is unset.
WA_DEV_TIER=

# P0 success-metric telemetry. The server emits fire-and-forget session_init and
# tool_call events to the API portal's /api/mcp-events endpoint (never blocks a
# tool call). Set to 1/true to disable emission entirely. See README →
# "Telemetry & success metrics".
WA_METRICS_DISABLED=
